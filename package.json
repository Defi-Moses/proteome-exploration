{
  "name": "pan-ccre",
  "private": true,
  "version": "0.1.0",
  "description": "Pangenome-aware registry of polymorphic human cCREs",
  "packageManager": "pnpm@10.6.2",
  "scripts": {
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "build": "pnpm -r build",
    "dev:api": "pnpm --filter @panccre/api dev",
    "dev:worker": "pnpm --filter @panccre/worker dev",
    "release:fixture": "python3 scripts/release_phase1.py --label fixture-release-001",
    "release:check": "python3 scripts/check_release_contract.py --release-manifest data/releases/fixture-release-001/release_manifest.json",
    "sources:bootstrap": "python3 scripts/bootstrap_real_data.py --config configs/sources/phase1_sources.yaml"
  }
}
